# =============================================
# COPIE ESTE ARQUIVO PARA .env.local
# e preencha com suas chaves reais
# NUNCA suba o .env.local para o GitHub
# =============================================

# --- CLERK (Autenticação) ---
# Crie sua conta em: https://clerk.com
# Dashboard > Seu App > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_COLOQUE_AQUI
CLERK_SECRET_KEY=sk_test_COLOQUE_AQUI

# Rotas do Clerk (não mude esses valores)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# --- SUPABASE (Banco de Dados) ---
# Crie seu projeto em: https://supabase.com
# Dashboard > Seu Projeto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.COLOQUE_AQUI
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.COLOQUE_AQUI

# --- DEEPSEEK (IA) ---
# Crie sua conta em: https://platform.deepseek.com
# Dashboard > API Keys > Create new key
DEEPSEEK_API_KEY=sk-COLOQUE_AQUI

# --- RESEND (E-mails automáticos) ---
# Crie sua conta em: https://resend.com
# Dashboard > API Keys > Create API Key
RESEND_API_KEY=re_COLOQUE_AQUI
# E-mail verificado no Resend (deve ser um domínio seu)
RESEND_FROM_EMAIL=JurisFlow <noreply@seudominio.com.br>
RESEND_FROM=JurisFlow <no-reply@seudominio.com.br>

# --- Z-API (WhatsApp automático) ---
# Crie sua conta em: https://z-api.io
# Dashboard > Instâncias > Criar instância > Conectar WhatsApp
ZAPI_INSTANCE_ID=SEU_INSTANCE_ID
ZAPI_TOKEN=SEU_TOKEN
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN

# --- STRIPE (Pagamentos) ---
# Crie sua conta em: https://stripe.com
# Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_COLOQUE_AQUI
STRIPE_WEBHOOK_SECRET=whsec_COLOQUE_AQUI

# --- DATAJUD / MONITORAMENTO ---
# URL base da API pública do CNJ (já tem valor padrão no código)
DATAJUD_API_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_API_KEY=COLOQUE_SUA_CHAVE

# --- APP ---
# URL pública da aplicação (localhost para dev, domínio real para produção)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- CRON (Jobs agendados) ---
# Chave secreta para proteger os endpoints de cron
CRON_SECRET=COLOQUE_UMA_SENHA_FORTE_AQUI
