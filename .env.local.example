# =============================================
# COPIE ESTE ARQUIVO PARA .env.local
# e preencha com suas chaves reais
# NUNCA suba o .env.local para o GitHub
# =============================================

# --- 
CLERK (Autenticação) ---
# Crie sua conta em: https://clerk.com
# Dashboard > Seu App > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_COLOQUE_AQUI
CLERK_SECRET_KEY=sk_test_COLOQUE_AQUI

# Rotas do Clerk (não mude esses valores)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# --- SUPABASE (Banco de Dados) ---
# Crie seu projeto em: https://supabase.com
# Dashboard > Seu Projeto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.COLOQUE_AQUI
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.COLOQUE_AQUI

# --- DEEPSEEK (IA) ---
# Crie sua conta em: https://platform.deepseek.com
# Dashboard > API Keys > Create new key
DEEPSEEK_API_KEY=sk-COLOQUE_AQUI

# --- RESEND (E-mails automáticos) ---
# Crie sua conta em: https://resend.com
# Dashboard > API Keys > Create API Key
RESEND_API_KEY=re_COLOQUE_AQUI
# E-mail verificado no Resend (deve ser um domínio seu)
RESEND_FROM_EMAIL=Jurivox <noreply@seudominio.com.br>
RESEND_FROM=Jurivox <no-reply@seudominio.com.br>

# --- Z-API (WhatsApp automático) ---
# Crie sua conta em: https://z-api.io
# Dashboard > Instâncias > Criar instância > Conectar WhatsApp
ZAPI_INSTANCE_ID="3F1BE7442175126B10290E8BC9274D54"
ZAPI_TOKEN="39794D4FE30379E93CA9ADE7"
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN

# --- STRIPE (Pagamentos) ---
# Crie sua conta em: https://stripe.com
# Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_COLOQUE_AQUI
STRIPE_WEBHOOK_SECRET=whsec_COLOQUE_AQUI

# Price IDs dos planos — crie em: Stripe Dashboard > Products > Add product
# Para cada plano, crie um produto e dois preços (mensal e anual).
# Copie o price_XXXX de cada um abaixo:
STRIPE_PRICE_STARTER_MENSAL=price_COLOQUE_AQUI
STRIPE_PRICE_STARTER_ANUAL=price_COLOQUE_AQUI
STRIPE_PRICE_PRO_MENSAL=price_COLOQUE_AQUI
STRIPE_PRICE_PRO_ANUAL=price_COLOQUE_AQUI
STRIPE_PRICE_ENTERPRISE_MENSAL=price_COLOQUE_AQUI
STRIPE_PRICE_ENTERPRISE_ANUAL=price_COLOQUE_AQUI

# --- DATAJUD / MONITORAMENTO ---
# URL base da API pública do CNJ (já tem valor padrão no código)
DATAJUD_API_URL="https://api-publica.datajud.cnj.jus.br"
# Solicite sua chave em: https://datajud-wiki.cnj.jus.br/api-publica/acesso
DATAJUD_API_KEY="cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw=="

# --- APP ---
# URL pública da aplicação (localhost para dev, domínio real para produção)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_CLIENT_ERROR_REPORTING=true

# --- CRON (Jobs agendados) ---
# Chave secreta para proteger os endpoints de cron (/api/cron/*)
CRON_SECRET=COLOQUE_UMA_SENHA_FORTE_AQUI

# --- MERCADO PAGO (Boletos e Pix) ---
# Crie sua conta em: https://www.mercadopago.com.br/developers
# Dashboard > Suas integrações > Credenciais > Access Token
# Para testes: use o token TEST-xxx (sandbox automático)
# Para produção: use o token APP_USR-xxx
# Aceita CPF e CNPJ — sem necessidade de CNPJ para abrir conta
MP_ACCESS_TOKEN=SEU_MP_ACCESS_TOKEN

# --- WEB PUSH (Notificações Push) ---
# Gere as chaves VAPID com: npx web-push generate-vapid-keys
# Ou acesse: https://vapidkeys.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=COLOQUE_CHAVE_PUBLICA_VAPID_AQUI
VAPID_PRIVATE_KEY=COLOQUE_CHAVE_PRIVADA_VAPID_AQUI
# E-mail de contato para o protocolo VAPID
VAPID_SUBJECT=mailto:contato@seudominio.com.br

# --- CRIPTOGRAFIA DE DADOS (Field-Level Encryption) ---
# OBRIGATÓRIO para salvar e ler dados de clientes, membros e escritórios.
# Gere as chaves com: node scripts/gerar-chave.mjs
#
# ENCRYPTION_KEY = 32 bytes (64 hex) — chave AES-256-GCM para criptografar campos PII
# HMAC_SECRET    = 32 bytes (64 hex) — chave HMAC-SHA256 para hashes de busca
#
# ⚠️ NUNCA compartilhe essas chaves. Se perdê-las, os dados encriptados são
#    irrecuperáveis. Salve em um gerenciador de senhas seguro.
ENCRYPTION_KEY=GERE_COM_node_scripts/gerar-chave.mjs
HMAC_SECRET=GERE_COM_node_scripts/gerar-chave.mjs

# --- TESTES E2E (Playwright) ---
# Credenciais de um usuário de teste no Clerk
TEST_EMAIL=
TEST_PASSWORD=
