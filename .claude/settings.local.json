      "Bash(npm install:*)",
      "Bash(where node:*)",
      "Read(//usr/local/**)",
      "Read(//c/Program Files/**)",
      "Read(//c/Users/ricarte/AppData/Roaming/**)",
      "Read(//c/Users/ricarte/AppData/Local/**)",
      "Bash(cmd /c \"where pnpm 2>nul\")",
